{
  "color": {
    "$type": "color",
    "base": {
      "blue": { "$value": "#0066ff" },
      "red": { "$value": "#e03131" },
      "gray": { "$value": "#9a9a9a" },
      "offWhite": { "$value": "#fafafa" }
    },
    "brand": {
      "primary": { "$value": "{color.base.blue}" }
    },
    "brandPrimary": {
      "$value": "#0066ff",
      "$description": "Duplicate of brand.primary — should be an alias"
    },
    "surface": {
      "default": {
        "$value": "{color.base.red}",
        "$description": "Oops — surface.default points to red instead of a neutral"
      },
      "bg_card": { "$value": "#ffffff" },
      "bgHero": { "$value": "#f0f2f5" }
    },
    "neutral": {
      "muted": {
        "$value": "#3366cc",
        "$description": "Named neutral but it's a saturated blue — semantic drift"
      },
      "subtle": {
        "$value": "#4488aa",
        "$description": "Another neutral with high saturation"
      }
    },
    "textMuted": { "$value": "#767676" },
    "text_secondary": { "$value": "#999999" },
    "gray": {
      "100": {
        "$value": "#f1f5fb",
        "$description": "Slightly blue-tinted gray — may trigger semantic drift"
      },
      "200": { "$value": "#e4eaf3" },
      "500": { "$value": "#8892a0" },
      "800": { "$value": "#343a40" }
    }
  },
  "spacing-sm": {
    "$type": "dimension",
    "$value": "8px"
  },
  "spacing-md": {
    "$type": "dimension",
    "$value": "16px"
  },
  "spacing-lg": {
    "$type": "dimension",
    "$value": "24px"
  },
  "spacing_xl": {
    "$type": "dimension",
    "$value": "32px"
  },
  "font": {
    "$type": "fontFamily",
    "family": {
      "sans": { "$value": "Inter, sans-serif" },
      "mono": { "$value": "JetBrains Mono, monospace" }
    },
    "size": {
      "bodyLarge": { "$value": "18px" },
      "heading_xl": { "$value": "36px" },
      "displayXXL": { "$value": "48px" }
    }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" }
  },
  "shadow": {
    "$type": "shadow",
    "cardShadow": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "12px",
        "spread": "0px",
        "color": "#0000001a"
      }
    },
    "drop_shadow_lg": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "-4px",
        "color": "#00000033"
      }
    }
  },
  "borderRadius": {
    "$type": "dimension",
    "$value": "8px",
    "$description": "Flat token at root level — should be nested under a group"
  },
  "legacy": {
    "$deprecated": true,
    "btn": {
      "$type": "color",
      "bg": { "$value": "#336699" },
      "hover": { "$value": "#264d73" }
    },
    "old": {
      "spacing": {
        "$type": "dimension",
        "gutter": { "$value": "20px" },
        "inset": { "$value": "12px" }
      }
    }
  }
}
